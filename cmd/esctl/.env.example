# esctl configuration. Copy to .env (or .env.local for personal
# overrides) — both are read at startup, .env.local wins.
#
# Explicit --flag arguments override env vars; env vars override
# .env file values; .env file values override built-in defaults.

# DB connection.
# Postgres:  postgres://user:pass@host:5432/dbname?sslmode=disable
# SQLite:    file:./events.db   or   sqlite:///abs/path/events.db
ESCTL_DB=postgres://localhost:5432/eventstore?sslmode=disable

# Default tenant for every subcommand (per-command --tenant overrides).
ESCTL_TENANT=

# Output format: "pretty" (default, human-readable) or "json" (one
# object per line; pipe into jq).
# ESCTL_OUTPUT=pretty

# Disable ANSI colour codes in pretty output. Also honours the
# standard NO_COLOR env var.
# ESCTL_NO_COLOR=1
